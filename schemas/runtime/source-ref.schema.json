{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^src_[a-f0-9]{32}$"
    },
    "kind": {
      "type": "string",
      "enum": [
        "brief",
        "figma",
        "openapi",
        "repository",
        "generated",
        "test-report",
        "other"
      ]
    },
    "locator": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "file"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "mediaType": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "type",
            "path"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "url"
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "mediaType": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "type",
            "url"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "figma"
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "fileKey": {
              "type": "string",
              "minLength": 1
            },
            "nodeId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "type",
            "url"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "repository"
            },
            "root": {
              "type": "string",
              "minLength": 1
            },
            "commit": {
              "type": "string",
              "pattern": "^[a-f0-9]{7,64}$"
            }
          },
          "required": [
            "type",
            "root"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "ticket"
            },
            "provider": {
              "type": "string",
              "enum": [
                "jira",
                "gitlab",
                "github",
                "notion",
                "linear"
              ]
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "externalId": {
              "type": "string",
              "minLength": 1
            },
            "mediaType": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "type",
            "provider",
            "url"
          ],
          "additionalProperties": false
        }
      ]
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "capturedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "metadata": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "id",
    "kind",
    "locator",
    "capturedAt",
    "metadata"
  ],
  "additionalProperties": false,
  "$id": "https://spec-to-pr.local/schemas/runtime/source-ref.schema.json"
}
