{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "0.1.0"
    },
    "id": {
      "type": "string",
      "pattern": "^run_[a-f0-9]{32}$"
    },
    "pluginVersion": {
      "type": "string",
      "minLength": 1
    },
    "projectRoot": {
      "type": "string",
      "minLength": 1
    },
    "baseCommit": {
      "type": "string",
      "pattern": "^[a-f0-9]{7,64}$"
    },
    "status": {
      "type": "string",
      "enum": [
        "created",
        "running",
        "blocked",
        "failed",
        "completed",
        "cancelled"
      ]
    },
    "revision": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "stageCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "gapCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "artifactCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "evidenceCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "agentResultCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "required": [
    "schemaVersion",
    "id",
    "pluginVersion",
    "projectRoot",
    "status",
    "revision",
    "createdAt",
    "updatedAt",
    "stageCount",
    "gapCount",
    "artifactCount",
    "evidenceCount",
    "agentResultCount"
  ],
  "additionalProperties": false,
  "$id": "https://spec-to-pr.local/schemas/runtime/run-summary.schema.json"
}
