{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^ev_[a-f0-9]{32}$"
    },
    "sourceId": {
      "type": "string",
      "pattern": "^src_[a-f0-9]{32}$"
    },
    "location": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "file-lines"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "startLine": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "endLine": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "type",
            "path",
            "startLine",
            "endLine"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "json-pointer"
            },
            "document": {
              "type": "string",
              "minLength": 1
            },
            "pointer": {
              "type": "string",
              "pattern": "^\\/.*"
            }
          },
          "required": [
            "type",
            "document",
            "pointer"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "figma-node"
            },
            "fileKey": {
              "type": "string",
              "minLength": 1
            },
            "nodeId": {
              "type": "string",
              "minLength": 1
            },
            "propertyPath": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          },
          "required": [
            "type",
            "fileKey",
            "nodeId"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "url-fragment"
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "fragment": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "type",
            "url",
            "fragment"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "pdf-page"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "page": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "type",
            "path",
            "page"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "pdf-text-block"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "page": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "blockIndex": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "type",
            "path",
            "page",
            "blockIndex"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "ticket-field"
            },
            "provider": {
              "type": "string",
              "enum": [
                "jira",
                "gitlab",
                "github",
                "notion",
                "linear"
              ]
            },
            "url": {
              "type": "string",
              "format": "uri"
            },
            "field": {
              "type": "string",
              "minLength": 1
            },
            "commentId": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "type",
            "provider",
            "url",
            "field"
          ],
          "additionalProperties": false
        },
        {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "const": "git-file"
            },
            "commit": {
              "type": "string",
              "pattern": "^[a-f0-9]{7,64}$"
            },
            "path": {
              "type": "string",
              "minLength": 1
            },
            "startLine": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            },
            "endLine": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "type",
            "commit",
            "path"
          ],
          "additionalProperties": false
        }
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "excerpt": {
      "type": "string",
      "maxLength": 4000
    },
    "digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "capturedAt": {
      "type": "string",
      "format": "date-time",
      "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z|([+-](?:[01]\\d|2[0-3]):[0-5]\\d)))$"
    },
    "metadata": {
      "default": {},
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {}
    }
  },
  "required": [
    "id",
    "sourceId",
    "location",
    "summary",
    "digest",
    "capturedAt",
    "metadata"
  ],
  "additionalProperties": false,
  "$id": "https://spec-to-pr.local/schemas/runtime/evidence-ref.schema.json"
}
