{
  "name": "@spec-to-pr/plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Claude Code plugin shell for evidence-driven spec-to-pr automation.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "format": "prettier . --write --ignore-unknown",
    "format:check": "prettier . --check --ignore-unknown",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "schemas:build": "tsx scripts/export-runtime-schemas.ts",
    "check": "pnpm format:check && pnpm typecheck && pnpm schemas:build && pnpm build && pnpm test",
    "plugin:validate": "claude plugin validate . --strict"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "yaml": "^2.9.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.9.0",
    "tsup": "^8.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.28.1"
    }
  }
}
